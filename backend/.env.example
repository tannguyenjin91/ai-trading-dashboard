# backend/.env.example

# --- AI Models ---
GEMINI_API_KEY=your_gemini_key
ANTHROPIC_API_KEY=your_claude_key
DNSE_API_KEY=your_dnse_key

# --- TCBS Broker ---
TCBS_USERNAME=your_username
TCBS_PASSWORD=your_password
TCBS_TOTP_SECRET=your_totp_secret
TCBS_ACCOUNT_NO=your_account

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# --- Infrastructure ---
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=sqlite+aiosqlite:///./audit.db

# --- Risk Toggles ---
LIVE_TRADING=false
STALE_DATA_THRESHOLD_SEC=60
