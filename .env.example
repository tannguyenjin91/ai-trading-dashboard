# .env.example
# Template for all environment variables required by vn-ai-trader.
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ─── AI Models ────────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
QWEN_API_KEY=your_qwen_api_key_here
DEFAULT_AI_MODEL=gemini              # Options: gemini | claude | qwen

# ─── TCBS Broker ──────────────────────────────────────────────────────────────
TCBS_USERNAME=your_tcbs_username
TCBS_PASSWORD=your_tcbs_password
TCBS_TOTP_SECRET=your_2fa_totp_secret_base32
TCBS_ACCOUNT_NO=your_account_number
TCBS_PAPER_MODE=true                 # true = simulation, false = real (if LIVE_TRADING=true)

# ─── Production Safety ────────────────────────────────────────────────────────
LIVE_TRADING=false                   # Final switch: true = REAL MONEY orders
STALE_DATA_THRESHOLD_SEC=60          # Reject if data > 60s old
DUPLICATE_SIGNAL_WINDOW_SEC=300      # Block same signal for 5 mins

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_TTL_TICK=1                     # seconds — tick data cache TTL
REDIS_TTL_OHLCV=300                  # seconds — OHLCV cache TTL (5 minutes)

# ─── Risk Management ──────────────────────────────────────────────────────────
MAX_RISK_PER_TRADE_PCT=2.0           # % of NAV maximum risk per trade
MAX_DAILY_DRAWDOWN_PCT=5.0           # % drawdown triggers killswitch
AGENT_CYCLE_INTERVAL=30              # seconds between AI agent loop runs
MIN_CONFLUENCE_SCORE=6               # minimum /10 to execute a trade
MIN_REWARD_RISK=2.0                  # minimum R:R ratio
MIN_CONFIDENCE_PCT=70                # minimum AI confidence % to execute

# ─── Circuit Breakers ─────────────────────────────────────────────────────────
DRAWDOWN_REDUCE_PCT=2.0              # reduce size 50% at this drawdown
DRAWDOWN_SCALPING_PCT=3.0            # scalping only mode
DRAWDOWN_CLOSE_ONLY_PCT=4.0          # close positions only
DRAWDOWN_KILLSWITCH_PCT=5.0          # full stop

# ─── Telegram Notifications ───────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./audit.db

# ─── Server ───────────────────────────────────────────────────────────────────
ENVIRONMENT=development              # development | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173
HOST=0.0.0.0
# ─── DNSE Broker ──────────────────────────────────────────────────────────────
DNSE_API_KEY=your_dnse_api_key_here
DNSE_USERNAME=                           # DNSE login (email/phone) for LightSpeed WebSocket (optional)
DNSE_PASSWORD=                           # DNSE login password for LightSpeed WebSocket (optional)

# ─── Realtime Data Feed ───────────────────────────────────────────────────────
REALTIME_POLL_INTERVAL=5.0               # Seconds between REST polling fallback (if WebSocket unavailable)
